Bootstrap: docker
From: nvidia/cuda:12.1.0-devel-ubuntu22.04

# Build from repo root so %files can see requirements: apptainer build qcg.sif containers/apptainer.def
%files
  requirements.txt /opt/requirements.txt
  requirements-vllm.txt /opt/requirements-vllm.txt
  requirements-cuda.txt /opt/requirements-cuda.txt

%post
  export DEBIAN_FRONTEND=noninteractive
  apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv git \
    && rm -rf /var/lib/apt/lists/*
  ln -sf /usr/bin/python3 /usr/bin/python
  pip install --upgrade pip
  pip install --no-cache-dir -r /opt/requirements.txt
  pip install --no-cache-dir -r /opt/requirements-vllm.txt
  pip install --no-cache-dir -r /opt/requirements-cuda.txt || true
  mkdir -p /workspace/query-conditioned-guidelines

%environment
  export PYTHONPATH=/workspace/query-conditioned-guidelines

%runscript
  exec bash -c "cd /workspace/query-conditioned-guidelines && exec bash"

%labels
  Author query-conditioned-guidelines
  Image qcg with vLLM and project deps
